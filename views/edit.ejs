<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Log | Sai Shiva Vasam</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <h1 class="page-title">Update Architecture Log</h1>
        
        <form action="/edit/<%= blog.id %>" method="POST" class="card">
            <div class="form-group">
                <label for="title">Document Title</label>
                <input type="text" id="title" name="title" required value="<%= blog.title %>">
            </div>
            
            <div class="form-group">
                <label for="content">Technical Content</label>
                <textarea id="content" name="content" required><%= blog.content %></textarea>
            </div>
            
            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn btn-primary" style="flex: 2;">Save Revisions</button>
                <a href="/blog/<%= blog.id %>" class="btn btn-danger" style="flex: 1; text-align: center; line-height: 2.5;">Cancel</a>
            </div>
        </form>
    </div>

    <%- include('partials/footer') %>
</body>
</html>